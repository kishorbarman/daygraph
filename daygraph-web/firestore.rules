rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isShortString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    function isDurationOrNull(value) {
      return value == null ||
        ((value is int || value is float) && value > 0 && value <= 10080);
    }

    function isScoreOrNull(value) {
      return value == null ||
        ((value is int || value is float) && value >= 1 && value <= 5);
    }

    function isTimestampOrNull(value) {
      return value == null || value is timestamp;
    }

    function isActivitySource(value) {
      return value == 'text' ||
        value == 'voice' ||
        value == 'preset' ||
        value == 'auto';
    }

    function hasOnlyKeys(data, allowed) {
      return data.keys().hasOnly(allowed);
    }

    function isValidUserDoc(data) {
      return hasOnlyKeys(
          data,
          [
            'displayName',
            'email',
            'photoURL',
            'timezone',
            'createdAt',
            'lastActiveAt',
            'onboardingCompleted',
            'onboardingCompletedAt',
            'lastResetAt',
          ],
        ) &&
        (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 120)) &&
        (!('email' in data) || (data.email is string && data.email.size() <= 320)) &&
        (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
        (!('timezone' in data) || isShortString(data.timezone, 100)) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('lastActiveAt' in data) || data.lastActiveAt is timestamp) &&
        (!('onboardingCompleted' in data) || data.onboardingCompleted is bool) &&
        (!('onboardingCompletedAt' in data) || isTimestampOrNull(data.onboardingCompletedAt)) &&
        (!('lastResetAt' in data) || data.lastResetAt is timestamp);
    }

    function isValidActivityDoc(data) {
      return hasOnlyKeys(
          data,
          [
            'activity',
            'category',
            'subCategory',
            'timestamp',
            'endTimestamp',
            'durationMinutes',
            'isPointInTime',
            'tags',
            'mood',
            'energy',
            'notes',
            'source',
            'rawInput',
            'createdAt',
            'editedAt',
          ],
        ) &&
        isShortString(data.activity, 200) &&
        isShortString(data.category, 64) &&
        isShortString(data.subCategory, 64) &&
        data.timestamp is timestamp &&
        isTimestampOrNull(data.endTimestamp) &&
        isDurationOrNull(data.durationMinutes) &&
        data.isPointInTime is bool &&
        data.tags is list &&
        data.tags.size() <= 10 &&
        isScoreOrNull(data.mood) &&
        isScoreOrNull(data.energy) &&
        (data.notes is string && data.notes.size() <= 1200) &&
        isActivitySource(data.source) &&
        (data.rawInput is string && data.rawInput.size() <= 1200) &&
        data.createdAt is timestamp &&
        isTimestampOrNull(data.editedAt);
    }

    function isValidActivitiesRawCreate(data) {
      return hasOnlyKeys(
          data,
          ['input', 'source', 'status', 'parsedActivityIds', 'createdAt', 'updatedAt'],
        ) &&
        isShortString(data.input, 1200) &&
        isActivitySource(data.source) &&
        data.status == 'pending' &&
        data.parsedActivityIds is list &&
        data.parsedActivityIds.size() == 0 &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    function isValidActivitiesRawRetry() {
      return hasOnlyKeys(
          request.resource.data,
          ['input', 'source', 'status', 'parsedActivityIds', 'createdAt', 'updatedAt'],
        ) &&
        request.resource.data.input == resource.data.input &&
        request.resource.data.source == resource.data.source &&
        request.resource.data.parsedActivityIds == resource.data.parsedActivityIds &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status == 'retried' &&
        request.resource.data.updatedAt is timestamp;
    }

    function isValidCorrectionDoc(data) {
      return hasOnlyKeys(
          data,
          [
            'activityId',
            'field',
            'originalValue',
            'correctedValue',
            'activityText',
            'correctedCategory',
            'createdAt',
          ],
        ) &&
        isShortString(data.activityId, 120) &&
        data.field == 'category' &&
        isShortString(data.originalValue, 64) &&
        isShortString(data.correctedValue, 64) &&
        isShortString(data.activityText, 200) &&
        isShortString(data.correctedCategory, 64) &&
        data.createdAt is timestamp;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidUserDoc(request.resource.data);
      allow delete: if false;

      match /activities/{activityId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidActivityDoc(request.resource.data);
        allow update: if isOwner(uid) &&
          isValidActivityDoc(request.resource.data) &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.source == resource.data.source &&
          request.resource.data.rawInput == resource.data.rawInput &&
          request.resource.data.notes == resource.data.notes;
        allow delete: if isOwner(uid);
      }

      match /activitiesRaw/{rawId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidActivitiesRawCreate(request.resource.data);
        allow update: if isOwner(uid) && isValidActivitiesRawRetry();
        allow delete: if false;
      }

      match /corrections/{correctionId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidCorrectionDoc(request.resource.data);
        allow update, delete: if false;
      }

      match /suggestionDismissals/{dismissalId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) &&
          hasOnlyKeys(request.resource.data, ['suggestionId', 'dismissedAt']) &&
          isShortString(request.resource.data.suggestionId, 120) &&
          request.resource.data.dismissedAt is timestamp;
        allow update, delete: if false;
      }

      match /appConfig/{docId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && (docId == 'presets' || docId == 'categories');
      }

      match /dailyStats/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /weeklyStats/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /aiTelemetry/{docId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /{subcollection}/{docId} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
